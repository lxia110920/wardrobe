<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>夢幻換裝小遊戲</title>
    <style>
        /* 基礎版面樣式 */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #ffe6f0, #e8f0fe);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        h1 {
            color: #ff6b9d;
            margin-bottom: 20px;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
        }

        /* 遊戲主容器 */
        .game-container {
            display: flex;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 20px;
            gap: 30px;
            max-width: 800px;
            width: 100%;
        }

        /* 左側：人物立繪區域 */
        .character-stage {
            flex: 1;
            background: #fff0f5;
            border-radius: 15px;
            border: 3px dashed #ffb6c1;
            height: 450px;
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        /* 衣服圖層疊加核心邏輯 */
        .layer {
            position: absolute;
            max-width: 100%;
            max-height: 100%;
            transition: all 0.3s ease;
        }

        /* 暫時用純文字/Emoji 模擬立繪與衣服的定位與大小 */
        .layer-body { font-size: 120px; z-index: 1; bottom: 80px; }
        .layer-hair { font-size: 90px; z-index: 4; top: 110px; }
        .layer-clothes { font-size: 100px; z-index: 3; bottom: 90px; }
        .layer-accessory { font-size: 60px; z-index: 5; top: 90px; }

        /* 右側：控制按鍵區域 */
        .control-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .category-title {
            font-weight: bold;
            color: #555;
            margin-bottom: 8px;
            border-left: 4px solid #ff6b9d;
            padding-left: 8px;
        }

        .btn-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 15px;
        }

        /* 按鍵樣式 */
        button {
            background-color: #f0f0f0;
            border: 2px solid #ddd;
            border-radius: 25px;
            padding: 10px 20px;
            font-size: 16px;
            cursor: pointer;
            transition: Taylor 0.2s ease, background-color 0.2s;
        }

        button:hover {
            background-color: #ffe6f0;
            border-color: #ff6b9d;
            transform: scale(1.05);
        }

        button.active {
            background-color: #ff6b9d;
            color: white;
            border-color: #ff4785;
        }

        /* 響應式設計：手機版自動直書排列 */
        @media (max-width: 600px) {
            .game-container {
                flex-direction: column;
            }
            .character-stage {
                height: 350px;
            }
        }
    </style>
</head>
<body>

    <h1>✨ 我的專屬換裝小遊戲 ✨</h1>

    <div class="game-container">
        <!-- 左側：人物與衣服立繪展示區 -->
        <div class="character-stage">
            <!-- 身體基底 -->
            <div class="layer layer-body" id="char-body">👧</div>
            <!-- 髮型圖層 -->
            <div class="layer layer-hair" id="char-hair">🎀</div>
            <!-- 衣服圖層 -->
            <div class="layer layer-clothes" id="char-clothes">👗</div>
            <!-- 配件圖層 -->
            <div class="layer layer-accessory" id="char-accessory">👑</div>
        </div>

        <!-- 右側：切換按鍵區 -->
        <div class="control-panel">
            
            <!-- 髮型切換 -->
            <div>
                <div class="category-title">選擇髮型 / 頭飾</div>
                <div class="btn-group">
                    <button class="active" onclick="changeItem('hair', '🎀', this)">蝴蝶結</button>
                    <button onclick="changeItem('hair', '🎩', this)">高頂帽</button>
                    <button onclick="changeItem('hair', '🧢', this)">棒球帽</button>
                    <button onclick="changeItem('hair', '', this)">無</button>
                </div>
            </div>

            <!-- 服裝切換 -->
            <div>
                <div class="category-title">選擇衣服</div>
                <div class="btn-group">
                    <button class="active" onclick="changeItem('clothes', '👗', this)">洋裝</button>
                    <button onclick="changeItem('clothes', '👘', this)">和服</button>
                    <button onclick="changeItem('clothes', '👚', this)">休閒服</button>
                    <button onclick="changeItem('clothes', '🦸‍♀️', this)">英雄披風</button>
                </div>
            </div>

            <!-- 配件切換 -->
            <div>
                <div class="category-title">選擇配件</div>
                <div class="btn-group">
                    <button class="active" onclick="changeItem('accessory', '👑', this)">皇冠</button>
                    <button onclick="changeItem('accessory', '🕶️', this)">墨鏡</button>
                    <button onclick="changeItem('accessory', '✨', this)">魔法光芒</button>
                    <button onclick="changeItem('accessory', '', this)">無</button>
                </div>
            </div>

        </div>
    </div>

    <script>
        /**
         * 換裝核心函式
         * @param {string} layerId - 要更換的圖層類別 ('hair', 'clothes', 'accessory')
         * @param {string} value - 要替換的內容（此處為 Emoji，未來可改為圖片 URL）
         * @param {HTMLElement} button - 被點擊的按鈕元素
         */
        function changeItem(layerId, value, button) {
            // 1. 找到對應的圖層並更新內容
            const targetLayer = document.getElementById(`char-${layerId}`);
            if (targetLayer) {
                targetLayer.innerText = value;
            }

            // 2. 更新按鈕的選取狀態（UI 視覺反饋）
            const btnGroup = button.parentElement;
            const buttons = btnGroup.getElementsByTagName('button');
            for (let btn of buttons) {
                btn.classList.remove('active');
            }
            button.classList.add('active');
        }
    </script>
</body>
</html>
